PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/voiceforge
JWT_SECRET=generate-random-32-char-string-here

# Smolify (optional, deprecated — use Gemini instead)
SMOLIFY_API_KEY=
SMOLIFY_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# Gemini (required for context extraction and Vapi LLM — aistudio.google.com)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=2
GEMINI_MAX_OUTPUT_TOKENS=800
GEMINI_CONTEXT_MAX_OUTPUT_TOKENS=800
GEMINI_AGENT_CONTEXT_MAX_OUTPUT_TOKENS=1000
# Optional tuning knobs
# GEMINI_TOP_P=0.8
# GEMINI_TOP_K=40
# GEMINI_STOP_SEQUENCES=```

# Context generation provider
CONTEXT_PROVIDER=hf

# Hugging Face context model
HF_MODEL_ID=Sayan25/smolified-file-context-extractor
HF_API_TOKEN=
# Optional custom endpoint URL (if using a dedicated Inference Endpoint)
HF_INFERENCE_URL=

# Vapi ($10 free)
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=random-secret-you-create-set-same-in-vapi-dashboard

# Cloudflare R2 (account ID has NO https:// prefix)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=voiceforge-uploads

# Alternate Cloudflare/AWS-style keys (supported by config.ts too)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_S3_API=https://<account-id>.r2.cloudflarestorage.com/<bucket-name>
AWS_REGION=auto
AWS_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Pinecone (create index with 768 dims for Gemini)
PINECONE_API_KEY=
PINECONE_INDEX=voiceforge-index

# Gmail OTP
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your-16-char-gmail-app-password

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URLs
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000

# After Railway deploy: set API_PUBLIC_URL to Railway URL
# Update Vapi assistant serverUrl to Railway URL once — no ngrok needed
